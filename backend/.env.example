# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=yph
DB_USER=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1

# JWT
JWT_ACCESS_TOKEN_LIFETIME=7  # days
JWT_REFRESH_TOKEN_LIFETIME=30  # days

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB

# Aliyun OSS (Optional)
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET_NAME=
ALIYUN_OSS_ENDPOINT=

# WeChat Pay (Optional)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# Alipay (Optional)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
